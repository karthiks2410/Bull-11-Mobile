    justifyContent: 'space-between',
    paddingVertical: 8,
    borderBottomWidth: 1,
    borderBottomColor: '#e0e0e0',
  },
  stockSymbol: {
    fontSize: 16,
    fontWeight: '600',
    color: '#333',
  },
  stockPrice: {
    fontSize: 16,
    color: '#666',
  },
  performanceContainer: {
    backgroundColor: '#f9f9f9',
    borderRadius: 8,
    padding: 12,
    marginBottom: 16,
  },
  performanceRow: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    marginBottom: 4,
  },
  performanceLabel: {
    fontSize: 14,
    color: '#666',
