# Bull-11 Mobile Environment Configuration
# Copy this file to .env and update with your values

# Backend API URL (no trailing slash)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# WebSocket URL for real-time updates (not currently used - polling instead)
EXPO_PUBLIC_WS_URL=ws://localhost:8080/ws

# Expo development server port (optional, default: 8081)
# PORT=5050
